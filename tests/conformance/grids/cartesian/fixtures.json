{
  "version": "1.0.0",
  "family": "cartesian",
  "tolerance": {
    "relative": 1e-14,
    "notes": "Per docs/GRIDS_API.md §4.2 default. Cartesian accessors are pure multiplications and linear interpolation of Float64 extents; no transcendentals are evaluated and the tight 1e-14 bound is expected to hold across all four bindings."
  },
  "reference_binding": "julia",
  "fixtures": [
    {
      "name": "small_1d",
      "opts": {
        "nx": 8,
        "extent": [[0.0, 1.0]],
        "ghosts": 0,
        "dtype": "float64"
      },
      "query_points": [[0], [1], [3], [4], [7]]
    },
    {
      "name": "small_2d",
      "opts": {
        "nx": 4,
        "ny": 3,
        "extent": [[0.0, 1.0], [0.0, 0.5]],
        "ghosts": 0,
        "dtype": "float64"
      },
      "query_points": [
        [0, 0], [0, 2], [3, 0], [3, 2],
        [1, 1], [2, 1], [1, 0], [0, 1]
      ]
    },
    {
      "name": "realistic_3d",
      "opts": {
        "nx": 16,
        "ny": 8,
        "nz": 4,
        "extent": [[0.0, 10.0], [-2.0, 2.0], [0.0, 1.0]],
        "ghosts": 0,
        "dtype": "float64"
      },
      "query_points": [
        [0, 0, 0], [15, 7, 3], [0, 7, 0], [15, 0, 3],
        [8, 4, 2], [7, 3, 1], [0, 0, 3], [15, 7, 0]
      ]
    },
    {
      "name": "nonuniform_2d",
      "opts": {
        "edges": [
          [0.0, 0.1, 0.3, 0.7, 1.0],
          [0.0, 0.5, 1.0, 1.5, 2.0]
        ],
        "ghosts": 0,
        "dtype": "float64"
      },
      "query_points": [
        [0, 0], [0, 3], [3, 0], [3, 3],
        [1, 1], [2, 2], [0, 2], [3, 1]
      ]
    }
  ]
}
