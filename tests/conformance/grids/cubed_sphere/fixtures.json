{
  "version": "1.0.0",
  "family": "cubed_sphere",
  "tolerance": {
    "relative": 1e-12,
    "notes": "Per docs/GRIDS_API.md §4.2 (per-family override). Cubed-sphere cell_area goes through cross, norm, acos — transcendental libm differences and accumulated roundoff push realistic-scale areas beyond the 1e-14 default. 1e-12 is empirically tight enough to catch real algorithm drift (observed bit-reordering errors land >1e-9) while stable across libm variants."
  },
  "reference_binding": "julia",
  "fixtures": [
    {
      "name": "small",
      "opts": {"Nc": 4, "R": 1.0, "ghosts": 0, "dtype": "float64"},
      "query_points": [
        [0, 0, 0], [0, 1, 2], [0, 3, 3], [0, 2, 0], [0, 0, 3],
        [1, 0, 0], [1, 3, 0], [1, 2, 2],
        [2, 0, 0], [2, 3, 3], [2, 1, 1],
        [3, 0, 2], [3, 3, 0],
        [4, 0, 0], [4, 2, 3],
        [5, 0, 0], [5, 3, 3], [5, 2, 1]
      ]
    },
    {
      "name": "realistic",
      "opts": {"Nc": 16, "R": 6371000.0, "ghosts": 0, "dtype": "float64"},
      "query_points": [
        [0, 0, 0], [0, 8, 8], [0, 15, 15], [0, 0, 15], [0, 15, 0],
        [1, 0, 7], [1, 15, 8], [1, 7, 0], [1, 8, 15],
        [2, 0, 0], [2, 15, 15], [2, 7, 7],
        [3, 0, 8], [3, 15, 8],
        [4, 0, 0], [4, 15, 0], [4, 7, 15],
        [5, 0, 0], [5, 15, 15], [5, 8, 7]
      ]
    }
  ]
}
