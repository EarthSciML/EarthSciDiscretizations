{
  "version": "1.0.0",
  "kind": "limiter_phi_sweep",
  "rule": "flux_limiter_superbee",
  "rule_family": "finite_volume",
  "comment": "Reference (r, phi(r)) pairs for the superbee limiter phi(r) = max(0, min(2*r, 1), min(r, 2)). The test loads the rule's ExpressionNode AST, evaluates it for each r via EarthSciSerialization.evaluate (the ESD eval_coeff passthrough), and compares to reference_values exactly. Sweep endpoints span r in [-2, 5]; checkpoints at r in {-1, 0, 0.5, 1, 1.5, 2, 3} per the bead acceptance list.",
  "variable": "r",
  "reference_values": [
    { "r": -2.0, "phi": 0.0 },
    { "r": -1.0, "phi": 0.0 },
    { "r": -0.5, "phi": 0.0 },
    { "r":  0.0, "phi": 0.0 },
    { "r":  0.25, "phi": 0.5 },
    { "r":  0.5, "phi": 1.0 },
    { "r":  0.75, "phi": 1.0 },
    { "r":  1.0, "phi": 1.0 },
    { "r":  1.5, "phi": 1.5 },
    { "r":  2.0, "phi": 2.0 },
    { "r":  3.0, "phi": 2.0 },
    { "r":  5.0, "phi": 2.0 }
  ],
  "tvd_properties": {
    "comment": "Properties the test must verify from the AST evaluation over the sweep r in [-2, 5] at 0.05 spacing.",
    "positivity": "phi(r) >= 0 for all r",
    "monotonicity_preserving": "phi(r) = 0 for r <= 0",
    "sweby_upper": "phi(r) <= 2 for all r",
    "consistency": "phi(1) = 1",
    "sweep_r_min": -2.0,
    "sweep_r_max": 5.0,
    "sweep_r_step": 0.05
  },
  "tolerance": 1e-12
}
