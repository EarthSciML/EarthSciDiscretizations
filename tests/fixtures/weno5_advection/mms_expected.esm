{
  "version": "1.0.0",
  "kind": "mms_convergence_expected",
  "rule": "weno5_advection",
  "rule_family": "finite_volume",
  "expected_min_order": 4.7,
  "theoretical_order": 5.0,
  "norm": "Linf",
  "comment": "Classical Jiang-Shu (1996) 5th-order WENO reconstruction on a uniform 1D Cartesian grid with periodic BC is theoretically O(dx^5) in L_inf for smooth solutions. The 4.7 floor accounts for the small accuracy hit from the nonlinear-weight recovery of linear weights (omega_k -> d_k) at finite eps = 1e-6, and leaves headroom for round-off."
}
