{
  "version": "1.0.0",
  "kind": "shock_capturing_expected",
  "rule": "weno5_advection",
  "rule_family": "finite_volume",
  "reference_envelope": { "min": 0.0, "max": 1.0 },
  "max_overshoot_tolerance": 0.05,
  "max_undershoot_tolerance": 0.05,
  "norm": "Linf",
  "comment": "The exact solution of linear advection of the square-wave initial condition after an integer number of periods on a periodic domain is the initial condition itself, so the reference final state envelope is [0, 1]. Classical Jiang-Shu WENO5 is not strictly TVD but spurious oscillations near the two discontinuities are small; both max overshoot above 1.0 and max undershoot below 0.0 must remain bounded by 0.05 to pass the qualitative shock-capturing check."
}
