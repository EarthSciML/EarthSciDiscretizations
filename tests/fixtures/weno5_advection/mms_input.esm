{
  "version": "1.0.0",
  "kind": "mms_convergence_input",
  "rule": "weno5_advection",
  "rule_family": "finite_volume",
  "domain": {
    "extent": [[0.0, 1.0]],
    "boundary": "periodic"
  },
  "manufactured_solution": {
    "name": "phase_shifted_sine",
    "expression": "sin(2*pi*x + 1.0)",
    "antiderivative": "-cos(2*pi*x + 1.0) / (2*pi)",
    "smoothness": "C^infinity",
    "comment": "Phase-shifted sine: critical points fall at x = (pi/2 - 1 + k*pi)/(2*pi) ~ 0.0908, 0.5908, neither of which coincides with a dyadic cell face on n in {32,64,128,256}. This avoids the well-known WENO5-JS accuracy dip that occurs when f'(x_{i+1/2}) = 0, where smoothness indicators beta_k degenerate and the omega_k -> d_k recovery stalls. Cell averages are integrated analytically (no quadrature error)."
  },
  "grids": [
    { "n": 32,  "uniform": true, "dx": 0.03125    },
    { "n": 64,  "uniform": true, "dx": 0.015625   },
    { "n": 128, "uniform": true, "dx": 0.0078125  },
    { "n": 256, "uniform": true, "dx": 0.00390625 }
  ],
  "norm": "Linf",
  "reconstruction": "left_biased",
  "weno_epsilon": 1e-6
}
