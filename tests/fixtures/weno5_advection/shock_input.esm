{
  "version": "1.0.0",
  "kind": "shock_capturing_input",
  "rule": "weno5_advection",
  "rule_family": "finite_volume",
  "domain": {
    "extent": [[0.0, 1.0]],
    "boundary": "periodic"
  },
  "initial_condition": {
    "name": "square_wave",
    "expression": "1 if 0.3 <= x <= 0.7 else 0",
    "smoothness": "discontinuous",
    "comment": "Unit-height square wave of width 0.4 centered on the domain. Cell averages on a uniform grid are computed analytically: cells fully inside [0.3, 0.7] average to 1, fully outside average to 0, partially overlapping cells average to the fraction of overlap."
  },
  "advection": {
    "velocity": 1.0,
    "periods": 1.0,
    "cfl": 0.4,
    "time_integrator": "ssp_rk3"
  },
  "grid": { "n": 200, "uniform": true, "dx": 0.005 },
  "reconstruction": "left_biased",
  "weno_epsilon": 1e-6
}
