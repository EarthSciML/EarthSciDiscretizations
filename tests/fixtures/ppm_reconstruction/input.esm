{
  "version": "1.0.0",
  "kind": "mms_convergence_input",
  "rule": "ppm_reconstruction",
  "rule_family": "finite_volume",
  "domain": {
    "extent": [[0.0, 1.0]],
    "boundary": "periodic"
  },
  "manufactured_solution": {
    "name": "smooth_periodic",
    "expression": "sin(2*pi*x) + 0.3*cos(4*pi*x)",
    "smoothness": "C^infinity",
    "comment": "Smooth periodic test function. Cell averages are integrated analytically per cell so the error measured is purely the PPM reconstruction error."
  },
  "grids": [
    { "n": 16,  "uniform": true, "dx": 0.0625    },
    { "n": 32,  "uniform": true, "dx": 0.03125   },
    { "n": 64,  "uniform": true, "dx": 0.015625  },
    { "n": 128, "uniform": true, "dx": 0.0078125 }
  ],
  "norm": "Linf",
  "samples_per_cell": 5
}
