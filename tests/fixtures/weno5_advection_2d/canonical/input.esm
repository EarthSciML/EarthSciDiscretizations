{
  "rule": "weno5_advection_2d",
  "comment": "Canonical 2D smooth-advection fixture for the weno5_advection_2d rule. Drives a 2D constant-velocity translation of a Gaussian plume on a periodic [0,1]^2 square (LeVeque (2002) Finite Volume Methods §20-style smooth-advection benchmark). The asymmetric velocity (u != v) and asymmetric Gaussian (sigma_x != sigma_y) ensure the dimension-by-dimension splitting exercises the x and y reconstruction paths independently, rather than collapsing to the 1D rule replicated twice.",
  "manufactured_solution": {
    "name": "gaussian_translate_2d",
    "expression": "q(x,y,t=0) = exp(-((x-0.5)^2/(2*sigma_x^2) + (y-0.5)^2/(2*sigma_y^2))); transported by (u, v) = (1.0, 2.0) on [0,1]^2 periodic. After T = 1.0 the Gaussian returns to (0.5, 0.5) (u*T = 1 wrap in x, v*T = 2 wraps in y)."
  },
  "grid": {
    "family": "cartesian",
    "nx": 32,
    "ny": 32,
    "extent": [[0.0, 1.0], [0.0, 1.0]],
    "periodic": [true, true]
  },
  "initial_condition": {
    "kind": "gaussian_2d",
    "amplitude": 1.0,
    "sigma_x": 0.1,
    "sigma_y": 0.15,
    "x0": 0.5,
    "y0": 0.5
  },
  "advection": {
    "velocity_x": 1.0,
    "velocity_y": 2.0,
    "cfl": 0.4,
    "periods": 1.0,
    "comment": "periods is the simulation length in dimensionless units; with u=1, v=2, L=1 the Gaussian translates exactly one wrap in x and two wraps in y over T=1.0."
  },
  "weno_epsilon": 1e-6,
  "boundary": "periodic"
}
