{
  "discretizations": {
    "upwind_1st": {
      "applies_to": {
        "op": "grad",
        "args": ["$u"],
        "dim": "$x"
      },
      "grid_family": "cartesian",
      "combine": "+",
      "accuracy": "O(dx)",
      "stencil": [
        {
          "selector": { "kind": "cartesian", "axis": "$x", "offset": -1 },
          "coeff": {
            "op": "/",
            "args": [-1, "dx"]
          }
        },
        {
          "selector": { "kind": "cartesian", "axis": "$x", "offset": 0 },
          "coeff": {
            "op": "/",
            "args": [1, "dx"]
          }
        }
      ]
    }
  }
}
