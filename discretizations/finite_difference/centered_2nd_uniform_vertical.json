{
  "discretizations": {
    "centered_2nd_uniform_vertical": {
      "applies_to": {
        "op": "grad",
        "args": ["$u"],
        "dim": "$k"
      },
      "grid_family": "vertical",
      "combine": "+",
      "accuracy": "O(h^2)",
      "stencil": [
        {
          "selector": { "kind": "vertical", "axis": "$k", "offset": -1 },
          "coeff": {
            "op": "/",
            "args": [-1, { "op": "*", "args": [2, "h"] }]
          }
        },
        {
          "selector": { "kind": "vertical", "axis": "$k", "offset": 1 },
          "coeff": {
            "op": "/",
            "args": [1, { "op": "*", "args": [2, "h"] }]
          }
        }
      ]
    }
  }
}
