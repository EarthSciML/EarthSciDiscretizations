{
  "discretizations": {
    "centered_2nd_uniform": {
      "applies_to": {
        "op": "grad",
        "args": ["$u"],
        "dim": "$x"
      },
      "grid_family": "cartesian",
      "accuracy": "O(dx^2)",
      "replacement": {
        "op": "arrayop",
        "output_idx": ["$x"],
        "expr": {
          "op": "/",
          "args": [
            {
              "op": "-",
              "args": [
                {
                  "op": "index",
                  "args": ["$u", { "op": "+", "args": ["$x", 1] }]
                },
                {
                  "op": "index",
                  "args": ["$u", { "op": "-", "args": ["$x", 1] }]
                }
              ]
            },
            { "op": "*", "args": [2, "dx"] }
          ]
        },
        "args": ["$u"]
      }
    }
  }
}
