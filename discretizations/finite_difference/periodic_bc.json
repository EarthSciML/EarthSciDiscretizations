{
  "rules": {
    "periodic_wrap_x": {
      "pattern": {
        "op": "index",
        "args": ["$u", "$expr_i", "$rest"]
      },
      "where": [
        { "guard": "dim_is_periodic", "pvar": "x", "grid": "$g" },
        { "guard": "var_has_grid", "pvar": "$u", "grid": "$g" }
      ],
      "replacement": {
        "op": "index",
        "args": [
          "$u",
          {
            "op": "mod",
            "args": [
              { "op": "+", "args": ["$expr_i", "Nx"] },
              "Nx"
            ]
          },
          "$rest"
        ]
      },
      "region": "xmin_boundary"
    }
  }
}
