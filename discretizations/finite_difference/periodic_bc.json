{
  "rules": {
    "periodic_wrap_x": {
      "pattern": {
        "op": "index",
        "args": [
          "$u",
          { "op": "-", "args": ["$i", "$offset"] },
          "$rest"
        ]
      },
      "where": [
        { "guard": "var_has_grid", "pvar": "$u", "grid": "$g" },
        { "guard": "dim_is_periodic", "pvar": "x", "grid": "$g" }
      ],
      "replacement": {
        "op": "index",
        "args": [
          "$u",
          {
            "op": "mod",
            "args": [
              {
                "op": "+",
                "args": [
                  { "op": "-", "args": ["$i", "$offset"] },
                  "Nx"
                ]
              },
              "Nx"
            ]
          },
          "$rest"
        ]
      },
      "region": "xmin_boundary"
    }
  }
}
