{
  "discretizations": {
    "centered_2nd_uniform_latlon": {
      "applies_to": {
        "op": "grad",
        "args": ["$u"],
        "dim": "$k"
      },
      "grid_family": "latlon",
      "combine": "+",
      "accuracy": "O(h^2)",
      "stencil": [
        {
          "selector": { "kind": "latlon", "axis": "lon", "offset": -1 },
          "coeff": {
            "op": "/",
            "args": [-1, { "op": "*", "args": [2, "R", "cos_lat", "dlon"] }]
          }
        },
        {
          "selector": { "kind": "latlon", "axis": "lon", "offset": 1 },
          "coeff": {
            "op": "/",
            "args": [1, { "op": "*", "args": [2, "R", "cos_lat", "dlon"] }]
          }
        },
        {
          "selector": { "kind": "latlon", "axis": "lat", "offset": -1 },
          "coeff": {
            "op": "/",
            "args": [-1, { "op": "*", "args": [2, "R", "dlat"] }]
          }
        },
        {
          "selector": { "kind": "latlon", "axis": "lat", "offset": 1 },
          "coeff": {
            "op": "/",
            "args": [1, { "op": "*", "args": [2, "R", "dlat"] }]
          }
        }
      ]
    }
  }
}
