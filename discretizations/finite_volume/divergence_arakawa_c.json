{
  "enums": {
    "arakawa_stagger": {
      "cell_center": 1,
      "face_x": 2,
      "face_y": 3,
      "vertex": 4
    }
  },
  "discretizations": {
    "divergence_arakawa_c": {
      "applies_to": {
        "op": "div",
        "args": ["$F"]
      },
      "grid_family": "arakawa",
      "stagger": "C",
      "requires_locations": ["face_x", "face_y"],
      "emits_location": "cell_center",
      "stagger_enum": "arakawa_stagger",
      "combine": "+",
      "accuracy": "O(h^2)",
      "reference": "Arakawa & Lamb (1977), Methods in Computational Physics 17:173-265 (C-grid staggering); canonical two-point centered finite-volume divergence with the x-component of F at face-x edges, the y-component at face-y edges, and the divergence emitted at cell centers.",
      "stencil": [
        {
          "selector": {
            "kind": "arakawa",
            "stagger": "face_x",
            "axis": "$x",
            "offset": 0
          },
          "coeff": { "op": "/", "args": [-1, "dx"] }
        },
        {
          "selector": {
            "kind": "arakawa",
            "stagger": "face_x",
            "axis": "$x",
            "offset": 1
          },
          "coeff": { "op": "/", "args": [1, "dx"] }
        },
        {
          "selector": {
            "kind": "arakawa",
            "stagger": "face_y",
            "axis": "$y",
            "offset": 0
          },
          "coeff": { "op": "/", "args": [-1, "dy"] }
        },
        {
          "selector": {
            "kind": "arakawa",
            "stagger": "face_y",
            "axis": "$y",
            "offset": 1
          },
          "coeff": { "op": "/", "args": [1, "dy"] }
        }
      ]
    }
  }
}
